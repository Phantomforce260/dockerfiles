CONVERSE_MODEL=Stheno
EMBED_MODEL=Nomic
CONTROLLER_MODEL=Llama-Instruct

# Context
CONVERSE_CTX_SIZE=4096
EMBEDDING_CTX_SIZE=512
CONTROLLER_CTX_SIZE=2048

# CPU tuning (Core Ultra ≈ 16 threads total)
THREADS=12

# Integrated GPU → keep disabled for stability
GPU_LAYERS=0

# Scale factor (single instance for now)
REPLICAS=1

CONVERSE_PORT=50500
EMBED_PORT=50501
CONTROLLER_PORT=50504
